generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String?  @unique
  email     String   @unique
  password  String
  name      String
  role      String   @default("TRABAJADOR")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Geolocalización del chofer
  latitude  Float?
  longitude Float?
  driverRoutes DeliveryRoute[] @relation("DriverRoutes")

  @@map("users")
}

model Supplier {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime       @default(now())
  parts     SupplierPart[]

  @@map("suppliers")
}

model SupplierPart {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  partId      Int
  cost        Float    @default(0)
  leadDays    Int      @default(1)
  isPreferred Boolean  @default(false)
  part        Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, partId])
  @@index([partId], map: "supplier_parts_partId_fkey")
  @@map("supplier_parts")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  parts       Part[]

  @@map("categories")
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String   @default("WAREHOUSE")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parts       Part[]

  @@map("locations")
}

model Part {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  sku           String?        @unique
  barcode       String?        @unique
  oemNumber     String?
  brand         String?
  price         Float          @default(0)
  priceFleet    Float?
  cost          Float          @default(0)
  quantity      Int            @default(0)
  minStock      Int            @default(0)
  categoryId    Int
  locationId    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fitment       Fitment[]
  category      Category       @relation(fields: [categoryId], references: [id])
  location      Location       @relation(fields: [locationId], references: [id])
  projectParts  ProjectPart[]
  quoteItems    QuoteItem[]
  supplierParts SupplierPart[]

  @@index([categoryId], map: "parts_categoryId_fkey")
  @@index([locationId], map: "parts_locationId_fkey")
  @@map("parts")
}

model VehicleModel {
  id        String    @id @default(cuid())
  make      String
  model     String
  yearStart Int
  yearEnd   Int?
  engine    String?
  trim      String?
  fitment   Fitment[]

  @@index([make, model])
  @@map("vehicle_models")
}

model Fitment {
  partId         Int
  vehicleModelId String
  notes          String?
  part           Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  vehicleModel   VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)

  @@id([partId, vehicleModelId])
  @@index([vehicleModelId], map: "fitment_vehicleModelId_fkey")
  @@map("fitment")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  address   String?
  rfc       String?
  type      String   @default("RETAIL")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fleet     Fleet?
  quotes    Quote[]

  @@map("customers")
}

model Fleet {
  id         String               @id @default(cuid())
  name       String
  customerId String               @unique
  notes      String?
  createdAt  DateTime             @default(now())
  units      FleetUnit[]
  customer   Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projects   MaintenanceProject[]

  @@map("fleets")
}

model FleetUnit {
  id        String               @id @default(cuid())
  fleetId   String
  year      Int
  make      String
  model     String
  trim      String?
  color     String?
  plate     String?              @unique
  vin       String?              @unique
  mileage   Int?
  engine    String?
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  fleet     Fleet                @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  projects  MaintenanceProject[]

  @@index([fleetId], map: "fleet_units_fleetId_fkey")
  @@map("fleet_units")
}

model MaintenanceProject {
  id               String        @id @default(cuid())
  projectNumber    String        @unique
  fleetId          String
  fleetUnitId      String
  name             String
  description      String?
  status           String        @default("OPEN")
  priority         String        @default("NORMAL")
  mileageAtService Int?
  startDate        DateTime?
  completedDate    DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  fleet            Fleet         @relation(fields: [fleetId], references: [id])
  fleetUnit        FleetUnit     @relation(fields: [fleetUnitId], references: [id])
  parts            ProjectPart[]

  @@index([fleetId], map: "maintenance_projects_fleetId_fkey")
  @@index([fleetUnitId], map: "maintenance_projects_fleetUnitId_fkey")
  @@map("maintenance_projects")
}

model ProjectPart {
  id        String             @id @default(cuid())
  projectId String
  partId    Int
  quantity  Int                @default(1)
  unitPrice Float              @default(0)
  notes     String?
  part      Part               @relation(fields: [partId], references: [id])
  project   MaintenanceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([partId], map: "project_parts_partId_fkey")
  @@index([projectId], map: "project_parts_projectId_fkey")
  @@map("project_parts")
}

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  status      String      @default("PENDING")
  customerId  String
  vehicleRef  String?
  notes       String?
  subtotal    Float       @default(0)
  tax         Float       @default(0)
  total       Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       QuoteItem[]
  customer    Customer    @relation(fields: [customerId], references: [id])

  // Datos de entrega y abasto
  deliveryType      String         @default("WILL_CALL") // "WILL_CALL", "DELIVERY"
  fulfillmentStatus String         @default("PENDING_STOCK_CHECK") // "PENDING_STOCK_CHECK", "AWAITING_STOCK", "PENDING_PICKUP", "PENDING_DELIVERY", "COMPLETED", "CANCELLED"
  supplierStatus    String         @default("NONE") // "NONE", "ORDERED", "RECEIVED"
  deliveryAddress   String?
  deliveryStops     DeliveryStop[]

  @@index([customerId], map: "quotes_customerId_fkey")
  @@map("quotes")
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  partId      Int
  description String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)
  amount      Float  @default(0)
  part        Part   @relation(fields: [partId], references: [id])
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([partId], map: "quote_items_partId_fkey")
  @@index([quoteId], map: "quote_items_quoteId_fkey")
  @@map("quote_items")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String
  userEmail  String
  userName   String?
  details    String?
  createdAt  DateTime @default(now())

  @@map("audit_log")
}

model FinancialEntry {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String
  isPaid      Boolean  @default(true)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("financial_entries")
}

model DeliveryRoute {
  id           String         @id @default(cuid())
  driverId     String?
  driver       User?          @relation("DriverRoutes", fields: [driverId], references: [id])
  status       String         @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED", "CANCELLED"
  startAddress String         @default("Av. Norte y Coahuila #58, Dolores Hidalgo, GTO")
  stops        DeliveryStop[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("delivery_routes")
}

model DeliveryStop {
  id              String        @id @default(cuid())
  routeId         String
  route           DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  sequence        Int
  type            String        // "PICKUP_PROVIDER" o "DELIVERY_CUSTOMER"
  quoteId         String?
  quote           Quote?        @relation(fields: [quoteId], references: [id])
  address         String
  latitude        Float?
  longitude       Float?
  contactName     String
  contactPhone    String
  details         String
  paymentStatus   String        // "PAID", "COLLECT"
  amountToCollect Float         @default(0)
  status          String        @default("PENDING") // "PENDING", "COMPLETED", "FAILED"
  failedReason    String?
  eta             DateTime?
  completedAt     DateTime?

  @@map("delivery_stops")
}
