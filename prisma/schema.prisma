// A/C Radiamex
// Venta de partes al detalle + Gestión de proyectos por flota
// Inspirado en patrones de sistemas NAPA / AutoZone / O'Reilly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS Y SEGURIDAD ──────────────────────────────────
model User {
  id        String   @id @default(cuid())
  username  String?  @unique
  email     String   @unique
  password  String
  name      String
  role      String   @default("TRABAJADOR") // ADMIN | SUPERVISOR | TRABAJADOR
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── PROVEEDORES ───────────────────────────────────────────
model Supplier {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  parts     SupplierPart[]
  createdAt DateTime @default(now())

  @@map("suppliers")
}

// Costo por proveedor (una parte puede comprarse a varios proveedores)
model SupplierPart {
  id          Int      @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  partId      Int
  part        Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  cost        Float    @default(0)
  leadDays    Int      @default(1)
  isPreferred Boolean  @default(false)

  @@unique([supplierId, partId])
  @@map("supplier_parts")
}

// ─── CATEGORÍAS Y UBICACIONES ─────────────────────────────
model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  parts       Part[]

  @@map("categories")
}

model Location {
  id    Int    @id @default(autoincrement())
  name  String @unique  // Ej: Estante A-1, Pasillo 2, Bodega
  parts Part[]

  @@map("locations")
}

// ─── CATÁLOGO DE REFACCIONES ───────────────────────────────
model Part {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  sku          String?  @unique
  barcode      String?  @unique
  oemNumber    String?  // Número de parte OEM
  brand        String?
  price        Float    @default(0)  // Precio al público
  priceFleet   Float?               // Precio especial para flotas
  cost         Float    @default(0)
  quantity     Int      @default(0)
  minStock     Int      @default(0)

  categoryId   Int
  category     Category @relation(fields: [categoryId], references: [id])

  locationId   Int
  location     Location @relation(fields: [locationId], references: [id])

  // Compatibilidad con modelos de vehículo (tabla de fitment)
  fitment      Fitment[]

  supplierParts SupplierPart[]
  quoteItems    QuoteItem[]
  projectParts  ProjectPart[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("parts")
}

// ─── CATÁLOGO DE MODELOS DE VEHÍCULOS (fitment) ───────────
// Catálogo de modelos de vehículos para búsqueda de compatibilidad.
// NO son vehículos físicos. Una entrada representa Nissan Sentra 2015-2019 2.0L
model VehicleModel {
  id        String  @id @default(cuid())
  make      String  // Nissan
  model     String  // Sentra
  yearStart Int
  yearEnd   Int?
  engine    String? // 2.0L, 3.5L V6
  trim      String? // XE, SE, LE

  fitment   Fitment[]

  @@index([make, model])
  @@map("vehicle_models")
}

// Tabla de compatibilidad parte ↔ modelo de vehículo
model Fitment {
  partId         Int
  vehicleModelId String
  notes          String? // "Solo versión con A/C"

  part         Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  vehicleModel VehicleModel @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)

  @@id([partId, vehicleModelId])
  @@map("fitment")
}

// ─── CLIENTES ──────────────────────────────────────────────
// type: RETAIL (comprador ocasional), FLEET (empresa con flota)
model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  address   String?
  rfc       String?
  type      String   @default("RETAIL") // RETAIL | FLEET
  notes     String?

  fleet     Fleet?
  quotes    Quote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

// ─── FLOTAS ────────────────────────────────────────────────
// Una flota pertenece a un cliente de tipo FLEET.
// Agrupa sus vehículos físicos y proyectos de mantenimiento.
model Fleet {
  id         String   @id @default(cuid())
  name       String
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  notes      String?

  units      FleetUnit[]
  projects   MaintenanceProject[]

  createdAt  DateTime @default(now())

  @@map("fleets")
}

// ─── UNIDADES DE FLOTA (vehículos físicos) ─────────────────
// Cada unidad es un vehículo real: tiene placas, VIN, kilometraje.
model FleetUnit {
  id       String  @id @default(cuid())
  fleetId  String
  fleet    Fleet   @relation(fields: [fleetId], references: [id], onDelete: Cascade)

  // Identificación del vehículo
  year     Int
  make     String
  model    String
  trim     String?
  color    String?
  plate    String?  @unique
  vin      String?  @unique
  mileage  Int?
  engine   String?
  notes    String?

  projects MaintenanceProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fleet_units")
}

// ─── PROYECTOS DE MANTENIMIENTO ────────────────────────────
// Proyecto de mantenimiento/reparación para una unidad de flota.
// Aquí se registran las partes a usar, descontando del inventario.
model MaintenanceProject {
  id            String  @id @default(cuid())
  projectNumber String  @unique // PROY-2026-0001
  fleetId       String
  fleet         Fleet   @relation(fields: [fleetId], references: [id])
  fleetUnitId   String
  fleetUnit     FleetUnit @relation(fields: [fleetUnitId], references: [id])

  name          String
  description   String?
  status        String   @default("OPEN")     // OPEN | IN_PROGRESS | WAITING_PARTS | COMPLETED | CANCELLED
  priority      String   @default("NORMAL")   // LOW | NORMAL | HIGH | URGENT
  mileageAtService Int?

  parts         ProjectPart[]

  startDate     DateTime?
  completedDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("maintenance_projects")
}

// Partes usadas en un proyecto de mantenimiento
model ProjectPart {
  id        String @id @default(cuid())
  projectId String
  project   MaintenanceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partId    Int
  part      Part   @relation(fields: [partId], references: [id])

  quantity  Int    @default(1)
  unitPrice Float  @default(0)
  notes     String?

  @@map("project_parts")
}

// ─── COTIZACIONES Y VENTAS (retail) ───────────────────────
model Quote {
  id          String   @id @default(cuid())
  quoteNumber String   @unique // COT-2026-0001
  status      String   @default("PENDING") // PENDING | SOLD | CANCELLED

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  // Vehículo de referencia (para anotar para qué auto son las partes)
  vehicleRef  String?  // ej. "Nissan Sentra 2018 2.0L" – texto libre o ID de VehicleModel
  notes       String?

  subtotal    Float    @default(0)
  tax         Float    @default(0)
  total       Float    @default(0)

  items       QuoteItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quotes")
}

model QuoteItem {
  id          String @id @default(cuid())
  quoteId     String
  partId      Int

  description String  // Snapshot del nombre de la parte
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  amount      Float   @default(0)

  quote       Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  part        Part  @relation(fields: [partId], references: [id])

  @@map("quote_items")
}

// ─── REGISTRO DE AUDITORÍA ─────────────────────────────────
model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   String
  userEmail  String
  userName   String?
  details    String?
  createdAt  DateTime @default(now())

  @@map("audit_log")
}
