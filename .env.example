# Configuración de Base de Datos (Hostinger MySQL)
# Formato: mysql://usuario:password@host:puerto/nombre_base_datos
DATABASE_URL="mysql://u123456789_user:password@127.0.0.1:3306/u123456789_db"

# Next Auth
# Puedes generar una con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="https://sistem.radiamex.com"

# Otras configuraciones
NODE_ENV="production"
